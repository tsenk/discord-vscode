{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "discord-vscode",
	"displayName": "Discord Presence",
	"version": "5.9.2",
	"description": "Update your discord status with a rich presence.",
	"private": true,
	"publisher": "icrawl",
	"scripts": {
		"build:check": "tsc --noEmit",
		"build": "pnpm run fmt && node esbuild.mjs && vsce package --no-dependencies --allow-star-activation",
		"fmt": "pnpm run build:check && prettier --write . && eslint --fix --format=pretty src"
	},
	"type": "commonjs",
	"main": "./dist/extension.cjs",
	"author": {
		"name": "iCrawl",
		"email": "icrawltogo@gmail.com"
	},
	"contributors": [
		{
			"name": "Frangu Vlad",
			"email": "kingdgrizzle@gmail.com"
		}
	],
	"license": "MIT",
	"keywords": [
		"discord",
		"vscode",
		"rich",
		"presence",
		"rich presence",
		"rpc"
	],
	"categories": [
		"Other"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/iCrawl/discord-vscode.git"
	},
	"bugs": {
		"url": "https://github.com/iCrawl/discord-vscode/issues"
	},
	"homepage": "https://github.com/iCrawl/discord-vscode#readme",
	"dependencies": {
		"@xhayper/discord-rpc": "^1.2.1"
	},
	"devDependencies": {
		"@types/lodash.merge": "^4.6.9",
		"@types/node": "^22.14.0",
		"@types/vscode": "^1.96.2",
		"@vscode/vsce": "^3.3.2",
		"esbuild": "^0.25.2",
		"eslint": "^9.24.0",
		"eslint-config-neon": "^0.2.7",
		"eslint-formatter-pretty": "^6.0.1",
		"eslint-import-resolver-typescript": "^4.3.2",
		"lodash.merge": "^4.6.2",
		"prettier": "^3.5.3",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.29.0"
	},
	"icon": "assets/icon.png",
	"galleryBanner": {
		"color": "#6477C1",
		"theme": "dark"
	},
	"activationEvents": [
		"*"
	],
	"extensionKind": [
		"ui"
	],
	"contributes": {
		"commands": [
			{
				"command": "discord.reconnect",
				"title": "Reconnect Discord Presence to Discord",
				"category": "Discord Presence"
			},
			{
				"command": "discord.disconnect",
				"title": "Disconnect Discord Presence from Discord",
				"category": "Discord Presence"
			}
		],
		"configuration": [
			{
				"title": "Discord Presence Configuration",
				"type": "object",
				"properties": {
					"discord.idleTimeout": {
						"type": "number",
						"default": 1800,
						"description": "Time (in seconds) to clear the presence when window is unfocused. 0 means no clearing"
					}
				}
			}
		]
	},
	"engines": {
		"vscode": "^1.96.2"
	},
	"packageManager": "pnpm@10.8.0"
}
